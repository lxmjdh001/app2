PORT=8088
DATABASE_URL=postgresql://chaoteng@127.0.0.1:5432/postgres
LOCAL_DEV_ALLOW_ANON=true

DISPATCH_INTERVAL_MS=3000
DISPATCH_BATCH_SIZE=20
MAX_JOB_ATTEMPTS=6

DEFAULT_ATTRIBUTION_LOOKBACK_HOURS=168
DEFAULT_ATTRIBUTION_RULE_NAME=last_touch_v1

FACEBOOK_API_VERSION=v21.0
TIKTOK_ENDPOINT=https://business-api.tiktok.com/open_api/v1.3/event/track/

JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES_IN=12h

# ClickHouse analytics layer (P2)
CLICKHOUSE_ENABLED=false
CLICKHOUSE_URL=http://127.0.0.1:8123
CLICKHOUSE_DATABASE=postback_analytics
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_REQUEST_TIMEOUT_MS=15000
